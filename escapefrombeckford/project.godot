; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[animation]

compatibility/default_parent_skeleton_in_mesh_instance_3d=true

[application]

config/name="escapefrombeckford"
run/main_scene="res://main_menu/main_menu.tscn"
config/features=PackedStringArray("4.6", "Forward Plus")
config/icon="res://icon.svg"

[audio]

buses/default_bus_layout="uid://dbgqy38x3r4ca"

[autoload]

Events="*res://core/events.gd"
Shaker="*res://core/shaker.gd"
MusicPlayer="*res://core/music_player.tscn"
SFXPlayer="*res://core/sfx_player.tscn"
FxLibrary="*res://VFX/fx_library.gd"
SaveService="*res://core/save_service.gd"
Autoload="*res://main_menu/autoload.gd"

[debug]

gdscript/warnings/unused_signal=0

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080
window/size/resizable=false
window/size/borderless=true
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"

[global_group]

ui_layer=""
player=""
enemies=""
allies=""
background=""
sim_host=""

[gui]

theme/default_font_multichannel_signed_distance_field=true
theme/custom="res://themes/wizard_theme.tres"

