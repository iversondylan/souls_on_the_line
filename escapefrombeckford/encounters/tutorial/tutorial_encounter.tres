[sub_resource type="Resource" id="EncounterDialogueAction_intro"]
script = ExtResource("4_dialogue_action")
dialogue_id = &"oswin_intro"
speaker_name = "Magister Oswin Carrel"
text_bbcode = "\"Ahem. Stated for the record: this is Magister Oswin Carrel, Assistant Director of Resonance Integration. Associate Magister Cole Hadyn joins me today for a combat exercise.\""

