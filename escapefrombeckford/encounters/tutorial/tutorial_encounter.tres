[sub_resource type="Resource" id="EncounterDialogueAction_spike_timing"]
script = ExtResource("4_dialogue_action")
dialogue_id = &"oswin_spike_timing"
speaker_name = "Magister Oswin Carrel"
text_bbcode = "\"Resonance Spike increases the attack damage of your allies, but only until the enemy turn, so only your allies behind you benefit. The damage bonus will be gone by the time your allies in front take their turn.\""

