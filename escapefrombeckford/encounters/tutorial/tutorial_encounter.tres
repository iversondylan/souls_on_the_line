[sub_resource type="Resource" id="EncounterDialogueAction_clone_fell"]
script = ExtResource("4_dialogue_action")
dialogue_id = &"oswin_clone_fell"
speaker_name = "Magister Oswin Carrel"
text_bbcode = "Your clone fought valiantly and protected you from harm. It was destroyed. But not to worry! The bit of soul it had is now safely in your discard pile. That's the great thing about summoning: your companions come back!"

