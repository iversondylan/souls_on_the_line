[gd_resource type="Resource" script_class="BattleData" format=3 uid="uid://trlxaybf7coq"]

[ext_resource type="Script" uid="uid://be1v8qevmc2xw" path="res://encounters/battle_data.gd" id="1_battle_data"]
[ext_resource type="Script" uid="uid://cfatj0ryn8uv3" path="res://combatants/combatant_data.gd" id="2_combatant_data"]
[ext_resource type="Script" uid="uid://dojghhx6llod0" path="res://encounters/_core/encounter_definition.gd" id="2_definition"]
[ext_resource type="Script" uid="uid://bcd8uhtxdbpsn" path="res://encounters/_core/encounter_dialogue_action.gd" id="4_dialogue_action"]
[ext_resource type="Script" uid="uid://c1gcos6skuvpg" path="res://encounters/_core/encounter_event_condition.gd" id="5_event_condition"]
[ext_resource type="Script" uid="uid://ux5euuse2pwx" path="res://encounters/_core/encounter_capability_set.gd" id="6_capabilities"]
[ext_resource type="Script" uid="uid://dlhcpba4e0l5c" path="res://encounters/_core/encounter_trigger.gd" id="7_trigger"]
[ext_resource type="Script" uid="uid://dh1bydv0adqsq" path="res://encounters/_core/encounter_step.gd" id="8_step"]
[ext_resource type="Resource" uid="uid://ca8pmrs5s8td1" path="res://combatants/enemies/TrainingDummy/training_dummy_data.tres" id="8_yv6di"]
[ext_resource type="Script" uid="uid://duv8xyedkq7d4" path="res://encounters/_core/encounter_insert_index_condition.gd" id="9_insert_condition"]

[sub_resource type="Resource" id="EncounterCapabilitySet_default"]
script = ExtResource("6_capabilities")
allowed_card_uids = null
allowed_target_ids = null
allowed_insert_indices = null

[sub_resource type="Resource" id="EncounterEventCondition_dialogue_ack"]
script = ExtResource("5_event_condition")
event_name = &"dialogue_acknowledged"

[sub_resource type="Resource" id="EncounterDialogueAction_intro"]
script = ExtResource("4_dialogue_action")
dialogue_id = &"oswin_intro"
speaker_name = "Magister Oswin Carrel"
text_bbcode = "Ahem. Stated for the record: this is Magister Oswin Carrel, Assistant Director of Resonance Integration. Associate Magister Cole Hadyn joins me today for a combat drill."

[sub_resource type="Resource" id="EncounterEventCondition_player_input"]
script = ExtResource("5_event_condition")
event_name = &"player_input_reached"

[sub_resource type="Resource" id="EncounterTrigger_intro_on_input"]
script = ExtResource("7_trigger")
id = &"intro_on_input"
conditions = [SubResource("EncounterEventCondition_player_input")]
actions = [SubResource("EncounterDialogueAction_intro")]

[sub_resource type="Resource" id="EncounterStep_intro_draw_one"]
script = ExtResource("8_step")
id = &"intro_draw_one"
next_step_id = &"post_intro_lock"
player_turn_draw_amount_override = 1
completion_conditions = [SubResource("EncounterEventCondition_dialogue_ack")]
triggers = [SubResource("EncounterTrigger_intro_on_input")]
capability_overrides = SubResource("EncounterCapabilitySet_default")

[sub_resource type="Resource" id="EncounterCapabilitySet_locked"]
script = ExtResource("6_capabilities")
can_end_turn = false
can_play_cards = false
can_swap = false
can_select_discard = false
allowed_card_uids = null
allowed_target_ids = null
allowed_insert_indices = null

[sub_resource type="Resource" id="EncounterStep_post_intro_lock"]
script = ExtResource("8_step")
id = &"post_intro_lock"
next_step_id = &"teach_front_clone_dialogue"
auto_advance_after_sec = 1.0
capability_overrides = SubResource("EncounterCapabilitySet_locked")

[sub_resource type="Resource" id="EncounterDialogueAction_front_instruction"]
script = ExtResource("4_dialogue_action")
dialogue_id = &"oswin_front_instruction"
speaker_name = "Magister Oswin Carrel"
text_bbcode = "Your ability to create perfect clones of yourself is useful in countless ways! For instance, try creating one [b]in front[/b] of you to protect yourself from the attack of that training golem."

[sub_resource type="Resource" id="EncounterStep_teach_front_clone_dialogue"]
script = ExtResource("8_step")
id = &"teach_front_clone_dialogue"
next_step_id = &"teach_front_clone_action"
entry_actions = [SubResource("EncounterDialogueAction_front_instruction")]
completion_conditions = [SubResource("EncounterEventCondition_dialogue_ack")]
capability_overrides = SubResource("EncounterCapabilitySet_locked")

[sub_resource type="Resource" id="EncounterCapabilitySet_front_clone"]
script = ExtResource("6_capabilities")
can_end_turn = false
can_swap = false
can_select_discard = false
allowed_card_uids = null
allowed_target_ids = null
allowed_insert_indices = PackedInt32Array(0)

[sub_resource type="Resource" id="EncounterEventCondition_card_played"]
script = ExtResource("5_event_condition")
event_name = &"card_played"

[sub_resource type="Resource" id="EncounterInsertIndexCondition_front"]
script = ExtResource("9_insert_condition")
accepted_indices = PackedInt32Array(0)

[sub_resource type="Resource" id="EncounterStep_teach_front_clone_action"]
script = ExtResource("8_step")
id = &"teach_front_clone_action"
completion_conditions = [SubResource("EncounterEventCondition_card_played"), SubResource("EncounterInsertIndexCondition_front")]
capability_overrides = SubResource("EncounterCapabilitySet_front_clone")
denied_message_bbcode = "Try creating a clone [b]in front[/b] of yourself first."

[sub_resource type="Resource" id="EncounterDefinition_tutorial"]
script = ExtResource("2_definition")
initial_step_id = &"intro_draw_one"
no_shuffle = true
steps = [SubResource("EncounterStep_intro_draw_one"), SubResource("EncounterStep_post_intro_lock"), SubResource("EncounterStep_teach_front_clone_dialogue"), SubResource("EncounterStep_teach_front_clone_action")]

[resource]
script = ExtResource("1_battle_data")
encounter_name = "Tutorial Drill"
enemies = Array[ExtResource("2_combatant_data")]([ExtResource("8_yv6di")])
encounter_definition = SubResource("EncounterDefinition_tutorial")
metadata/_custom_type_script = "uid://be1v8qevmc2xw"
