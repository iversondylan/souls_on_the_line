[sub_resource type="Resource" id="EncounterDialogueAction_research_intro"]
script = ExtResource("4_dialogue_action")
dialogue_id = &"oswin_research_intro"
speaker_name = "Magister Oswin Carrel"
text_bbcode = "\"Good. Now that you know the basics of combat, it's finally time to conduct some research! Try casting Resonance Spike and see if it has an effect on your clones. If so, that means Convocation magic is compatible with paranormal entities.\""

