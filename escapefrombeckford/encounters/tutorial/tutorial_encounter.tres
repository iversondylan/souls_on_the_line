dialogue_id = &"oswin_spike_success"
speaker_name = "Magister Oswin Carrel"
text_bbcode = "\"Sweet mother of resonance, it worked! You can Convoke with your clones!\" [i]Oswin scribbles notes furiously.[/i]"

