[gd_resource type="Resource" script_class="CardData" format=3]

[ext_resource type="Script" path="res://cards/_core/card_action.gd" id="1_card_action"]
[ext_resource type="Script" path="res://cards/_core/card_data.gd" id="2_card_data"]
[ext_resource type="Resource" path="res://cards/souls/AyeAyeAsceticCard/summon_aye_aye_ascetic.tres" id="3_summon"]
[ext_resource type="Resource" path="res://cards/souls/AyeAyeAsceticCard/aye_aye_threshold_on_summoned_action.tres" id="4_threshold"]
